# Copy to ".env.local" for local dev (never commit secrets).
# GitHub Actions: add the same keys as repository Secrets for production builds.

# Required for silent email via Formspree (see Formspree dashboard → Integration → form endpoint).
VITE_FORMSPREE_FORM_ID=

# Optional: valid email Formspree uses as Reply-To on outbound mail (e.g. shared facilities inbox).
VITE_FORMSPREE_REPLY_EMAIL=

# Optional: mailto "To:" when Formspree ID is not set (offline fallback).
VITE_RESTOCK_MAIL_TO=
